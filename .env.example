# Ollama Configuration
# Cloud models and web search use https://ollama.com.
# For a local Ollama server, use OLLAMA_BASE_URL=http://localhost:11434.
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_API_KEY=
DEFAULT_MODEL=gemma4:31b-cloud

# Local SQLite database. You can use another SQLite path for tests.
DATABASE_URL=sqlite:stock_agent.db

# Market data. MARKET_API enables Finnhub with Yahoo Finance fallback.
MARKET_API=
FINNHUB_BASE_URL=https://finnhub.io/api/v1
MARKET_DATA_BASE_URL=https://query1.finance.yahoo.com
MARKET_DATA_CACHE_TTL_SECS=300
